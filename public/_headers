# public/_headers
# Headers de seguridad para Cloudflare Pages
# Equivalente a las reglas que tenías en netlify.toml

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://googleads.g.doubleclick.net https://api.web3forms.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://www.googletagmanager.com https://www.google-analytics.com; connect-src 'self' https://www.google-analytics.com https://api.web3forms.com; frame-src 'self' https://www.google.com

# Cache inmutable para assets estáticos
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Imágenes con cache largo
/hero/*
  Cache-Control: public, max-age=2592000

/proyectos/*
  Cache-Control: public, max-age=2592000

# Favicons
/favicon*
  Cache-Control: public, max-age=604800
