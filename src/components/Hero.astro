---
// src/components/Hero.astro
// Hero fullscreen con slider de imágenes + soporte video de fondo.
// Cada slide puede tener: imagen de fondo, título grande y subtítulo.
// Auto-rotación derecha→izquierda con dots de navegación.

interface HeroSlide {
  /** Ruta de la imagen de fondo (en /public/) */
  image?: string;
  /** Título grande del slide (ej: "Terrazas") */
  title: string;
  /** Subtítulo opcional debajo del título */
  subtitle?: string;
}

// ============================================================
// CONFIGURACIÓN DE SLIDES
// Editar aquí para agregar/cambiar slides del hero.
// Las imágenes van en /public/hero/ (crear la carpeta).
// ============================================================
const slides: HeroSlide[] = [
  {
    image: '/hero/slide-01.jpg',
    title: 'TodoCasa\nConstrucciones',
    subtitle: '«Tú lo imaginas, nosotros lo construimos»',
  },
  {
    image: '/hero/slide-02.jpg',
    title: 'Terrazas',
    subtitle: '«Tú lo imaginas, nosotros lo construimos»',
  },
  {
    image: '/hero/slide-03.jpg',
    title: 'Quinchos',
    subtitle: '«Tú lo imaginas, nosotros lo construimos»',
  },
  {
    image: '/hero/slide-04.jpg',
    title: 'Ampliaciones',
    subtitle: '«Tú lo imaginas, nosotros lo construimos»',
  },
  {
    image: '/hero/slide-05.jpg',
    title: 'Piscinas',
    subtitle: '«Tú lo imaginas, nosotros lo construimos»',
  },
];

// ============================================================
// VIDEO DE FONDO (opcional)
// Formatos recomendados: .mp4 (H.264) o .webm (VP9)
// Peso ideal: < 5MB para carga rápida.
// Si heroVideo está vacío, se usa solo el slider de imágenes.
// ============================================================
const heroVideo = '/hero/video-fondo.mp4';
const heroVideoPoster = '/hero/slide-01.jpg';
---

<section id="inicio" class="hero-slider relative w-full overflow-hidden" style="height: 100vh; min-height: 600px;">

  <!-- ===== VIDEO DE FONDO (capa más baja) ===== -->
  <div class="hero-video-layer absolute inset-0 z-0">
    <video
      id="hero-video"
      class="absolute inset-0 w-full h-full object-cover"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster={heroVideoPoster}
    >
      <source src={heroVideo} type="video/mp4" />
      <!-- Agregar .webm como fallback -->
      <!-- <source src="/hero/video-fondo.webm" type="video/webm" /> -->
    </video>
    <!-- Overlay oscuro sobre el video -->
    <div class="absolute inset-0 bg-black/50"></div>
  </div>

  <!-- ===== SLIDER DE IMÁGENES (sobre el video) ===== -->
  <div id="hero-track" class="hero-track absolute inset-0 z-10 flex transition-transform duration-700" style={`width: ${slides.length * 100}%;`}>
    {slides.map((slide, i) => (
      <div
        class="hero-slide relative flex-shrink-0 flex items-center justify-center"
        style={`width: ${100 / slides.length}%;`}
        data-index={i}
      >
        <!-- Imagen de fondo del slide -->
        {slide.image && (
          <div class="absolute inset-0">
            <img
              src={slide.image}
              alt={slide.title.replace('\n', ' ')}
              class="w-full h-full object-cover"
              loading={i === 0 ? 'eager' : 'lazy'}
              decoding={i === 0 ? 'sync' : 'async'}
              onerror="this.parentElement.style.display='none'"
            />
          </div>
        )}

        <!-- Overlay oscuro por slide -->
        <div class="absolute inset-0 bg-black/40"></div>

        <!-- Contenido del slide -->
        <div class="relative z-20 text-center px-4 max-w-5xl mx-auto hero-slide-content">
          <h2 class="hero-title" set:html={slide.title.replace('\n', '<br/>')} />

          {slide.subtitle && (
            <p class="hero-subtitle">{slide.subtitle}</p>
          )}

          <a href="#contacto" class="hero-cta">
            Cotiza Tu Proyecto
          </a>
        </div>
      </div>
    ))}
  </div>

  <!-- ===== FLECHAS DE NAVEGACIÓN ===== -->
  <button
    type="button"
    id="hero-prev"
    class="hero-arrow hero-arrow-prev"
    aria-label="Slide anterior"
  >
    <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
    </svg>
  </button>
  <button
    type="button"
    id="hero-next"
    class="hero-arrow hero-arrow-next"
    aria-label="Slide siguiente"
  >
    <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </button>

  <!-- ===== DOTS ===== -->
  <div class="hero-dots" id="hero-dots">
    {slides.map((_, i) => (
      <button
        type="button"
        class={`hero-dot ${i === 0 ? 'active' : ''}`}
        data-slide={i}
        aria-label={`Ir al slide ${i + 1}`}
      />
    ))}
  </div>

  <!-- ===== WAVE INFERIOR ===== -->
  <div class="absolute bottom-0 left-0 right-0 z-30 pointer-events-none" aria-hidden="true">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto block">
      <path d="M0 30L60 28C120 26 240 22 360 24C480 26 600 34 720 36C840 38 960 34 1080 30C1200 26 1320 22 1380 20L1440 18V61H0V30Z" style="fill: var(--bg-body);" />
    </svg>
  </div>
</section>

<style>
  /* ===== Tipografía Hero ===== */
  .hero-title {
    font-family: 'Playfair Display', 'Georgia', 'Times New Roman', serif;
    font-size: clamp(3rem, 10vw, 8rem);
    font-weight: 400;
    color: white;
    line-height: 1.05;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.4);
    margin-bottom: 1rem;
    opacity: 0;
    transform: translateY(30px);
    animation: fadeSlideUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
  }

  .hero-subtitle {
    font-family: var(--font-sans);
    font-size: clamp(0.95rem, 2vw, 1.2rem);
    color: rgba(255, 255, 255, 0.8);
    font-style: italic;
    letter-spacing: 0.02em;
    margin-bottom: 2rem;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.3);
    opacity: 0;
    transform: translateY(20px);
    animation: fadeSlideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.5s forwards;
  }

  .hero-cta {
    display: inline-block;
    padding: 0.85rem 2.5rem;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: white;
    background: var(--color-accent-500);
    border: none;
    transition: all 0.3s ease;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeSlideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.7s forwards;
  }

  .hero-cta:hover {
    background: var(--color-accent-600);
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(200, 148, 74, 0.35);
  }

  /* ===== Slide transition resets ===== */
  .hero-slide-content.transitioning .hero-title,
  .hero-slide-content.transitioning .hero-subtitle,
  .hero-slide-content.transitioning .hero-cta {
    animation: none;
    opacity: 0;
    transform: translateY(30px);
  }

  .hero-slide-content.animating .hero-title {
    animation: fadeSlideUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.15s forwards;
  }
  .hero-slide-content.animating .hero-subtitle {
    animation: fadeSlideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.35s forwards;
  }
  .hero-slide-content.animating .hero-cta {
    animation: fadeSlideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.5s forwards;
  }

  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ===== Arrows ===== */
  .hero-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 30;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: white;
    cursor: pointer;
    transition: all 0.3s ease;
    border-radius: 0;
  }

  .hero-arrow:hover {
    background: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .hero-arrow-prev { left: 1rem; }
  .hero-arrow-next { right: 1rem; }

  @media (min-width: 768px) {
    .hero-arrow-prev { left: 2rem; }
    .hero-arrow-next { right: 2rem; }
  }

  /* ===== Dots ===== */
  .hero-dots {
    position: absolute;
    bottom: 4.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 30;
    display: flex;
    gap: 0.6rem;
  }

  .hero-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.6);
    background: transparent;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .hero-dot.active {
    background: white;
    border-color: white;
  }

  .hero-dot:hover:not(.active) {
    background: rgba(255, 255, 255, 0.4);
  }

  /* ===== Hide video layer when no video loads ===== */
  .hero-video-layer video[data-error="true"] {
    display: none;
  }
</style>

<script>
  // ============================================================
  // HERO SLIDER — Auto-rotate + navigation
  // ============================================================
  const track = document.getElementById('hero-track') as HTMLElement;
  const dots = document.querySelectorAll<HTMLButtonElement>('.hero-dot');
  const prevBtn = document.getElementById('hero-prev');
  const nextBtn = document.getElementById('hero-next');
  const slides = document.querySelectorAll<HTMLElement>('.hero-slide');
  const totalSlides = slides.length;

  let currentSlide = 0;
  let autoplayTimer: ReturnType<typeof setInterval>;
  const AUTOPLAY_INTERVAL = 5000; // 5 segundos por slide

  function goToSlide(index: number, animate = true) {
    if (index < 0) index = totalSlides - 1;
    if (index >= totalSlides) index = 0;

    // Reset content animations for current slide
    const currentContent = slides[currentSlide]?.querySelector('.hero-slide-content');
    currentContent?.classList.remove('animating');
    currentContent?.classList.add('transitioning');

    currentSlide = index;

    // Move track
    if (animate) {
      track.style.transition = 'transform 0.7s cubic-bezier(0.16, 1, 0.3, 1)';
    } else {
      track.style.transition = 'none';
    }
    track.style.transform = `translateX(-${index * (100 / totalSlides)}%)`;

    // Update dots
    dots.forEach((dot, i) => dot.classList.toggle('active', i === index));

    // Trigger content animation for new slide
    const newContent = slides[index]?.querySelector('.hero-slide-content');
    if (newContent) {
      newContent.classList.remove('animating');
      newContent.classList.add('transitioning');
      // Force reflow
      void (newContent as HTMLElement).offsetWidth;
      newContent.classList.remove('transitioning');
      newContent.classList.add('animating');
    }
  }

  function nextSlide() { goToSlide(currentSlide + 1); }
  function prevSlide() { goToSlide(currentSlide - 1); }

  function startAutoplay() {
    stopAutoplay();
    autoplayTimer = setInterval(nextSlide, AUTOPLAY_INTERVAL);
  }

  function stopAutoplay() {
    if (autoplayTimer) clearInterval(autoplayTimer);
  }

  // Event listeners
  nextBtn?.addEventListener('click', () => { nextSlide(); startAutoplay(); });
  prevBtn?.addEventListener('click', () => { prevSlide(); startAutoplay(); });

  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      goToSlide(Number(dot.dataset.slide));
      startAutoplay();
    });
  });

  // Pause on hover
  const heroSection = document.querySelector('.hero-slider');
  heroSection?.addEventListener('mouseenter', stopAutoplay);
  heroSection?.addEventListener('mouseleave', startAutoplay);

  // Touch swipe support
  let touchStartX = 0;
  let touchEndX = 0;

  heroSection?.addEventListener('touchstart', (e) => {
    touchStartX = (e as TouchEvent).changedTouches[0].screenX;
    stopAutoplay();
  }, { passive: true });

  heroSection?.addEventListener('touchend', (e) => {
    touchEndX = (e as TouchEvent).changedTouches[0].screenX;
    const diff = touchStartX - touchEndX;
    if (Math.abs(diff) > 50) {
      if (diff > 0) nextSlide(); else prevSlide();
    }
    startAutoplay();
  }, { passive: true });

  // Keyboard
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowRight') { nextSlide(); startAutoplay(); }
    if (e.key === 'ArrowLeft') { prevSlide(); startAutoplay(); }
  });

  // Video error handling — hide video layer if no video found
  const heroVideo = document.getElementById('hero-video') as HTMLVideoElement;
  heroVideo?.addEventListener('error', () => {
    heroVideo.dataset.error = 'true';
    heroVideo.closest('.hero-video-layer')?.classList.add('hidden');
  });

  // If video source fails
  heroVideo?.querySelector('source')?.addEventListener('error', () => {
    heroVideo.dataset.error = 'true';
    heroVideo.closest('.hero-video-layer')?.classList.add('hidden');
  });

  // Start
  startAutoplay();
</script>
