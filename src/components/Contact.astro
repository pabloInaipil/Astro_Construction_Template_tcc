---
// src/components/Contact.astro
// Formulario de contacto con integración Web3Forms (Cloudflare-compatible).
// Layout split: formulario + info de contacto.

import { siteConfig } from '@config/site';

const { services, phone, phoneDisplay, email, whatsapp, whatsappMessage } = siteConfig;

// Web3Forms access key — obtener en https://web3forms.com/
// ← CAMBIAR: reemplazar con la access key real
const WEB3FORMS_KEY = '03b2d1fd-46d0-478a-abaf-797e043fd161';
---

<section id="contacto" class="py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-14 reveal">
      <span class="inline-block mb-3 text-xs font-semibold uppercase tracking-[0.2em]" style="color: var(--color-accent-600);">
        Contáctanos
      </span>
      <h2 class="section-title mb-4">
        ¿Tienes un proyecto en mente?
      </h2>
      <p class="section-subtitle mx-auto">
        Cuéntanos tu idea y te entregaremos una cotización sin compromiso.
        Respondemos en menos de 24 horas.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-14">

      <!-- Contact Form (3 cols) -->
      <div class="lg:col-span-3 reveal">
        <form
          class="space-y-5"
          id="contact-form"
        >
          {/* Web3Forms config */}
          <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
          <input type="hidden" name="subject" value={`Nueva cotización — ${siteConfig.name}`} />
          <input type="hidden" name="from_name" value={siteConfig.name} />
          <input type="hidden" name="ccemail" value="metalicomiguel@yahoo.es" />

          {/* Honeypot anti-spam (Web3Forms) */}
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

          {/* Row: Nombre + Teléfono */}
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="nombre" class="form-label">Nombre completo *</label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                autocomplete="name"
                placeholder="Juan Pérez"
                class="form-input"
              />
            </div>
            <div>
              <label for="telefono" class="form-label">Teléfono *</label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                required
                autocomplete="tel"
                placeholder={phoneDisplay}
                class="form-input"
              />
            </div>
          </div>

          {/* Email */}
          <div>
            <label for="email" class="form-label">Correo electrónico</label>
            <input
              type="email"
              id="email"
              name="email"
              autocomplete="email"
              placeholder="juan@ejemplo.cl"
              class="form-input"
            />
          </div>

          {/* Servicio */}
          <div>
            <label for="servicio" class="form-label">Servicio de interés *</label>
            <select id="servicio" name="servicio" required class="form-input">
              <option value="" disabled selected>Selecciona un servicio</option>
              {services.map((svc) => (
                <option value={svc.title}>{svc.title}</option>
              ))}
              <option value="Otro">Otro</option>
            </select>
          </div>

          {/* Mensaje */}
          <div>
            <label for="mensaje" class="form-label">Describe tu proyecto *</label>
            <textarea
              id="mensaje"
              name="mensaje"
              required
              rows={5}
              placeholder="Cuéntanos sobre tu proyecto: dimensiones aproximadas, ubicación, tipo de estructura, plazos..."
              class="form-input resize-y"
            ></textarea>
          </div>

          {/* Submit */}
          <div>
            <button
              type="submit"
              class="btn-primary w-full sm:w-auto px-10 py-3.5 text-base gap-2"
              id="submit-btn"
            >
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              Enviar Cotización
            </button>
          </div>

          {/* Success/Error messages */}
          <div id="form-success" class="hidden p-4 rounded-xl text-sm font-medium" style="background: var(--color-accent-100); color: var(--color-primary-800);">
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              ¡Mensaje enviado! Te contactaremos pronto.
            </div>
          </div>

          <div id="form-error" class="hidden p-4 rounded-xl text-sm font-medium bg-red-50 text-red-800">
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Hubo un error al enviar. Intenta nuevamente o contáctanos por WhatsApp.
            </div>
          </div>
        </form>
      </div>

      <!-- Contact Info (2 cols) -->
      <div class="lg:col-span-2 reveal">
        <div class="rounded-2xl p-7 lg:p-8 h-full"
          style="background-color: var(--color-primary-950); color: var(--color-surface-300);">

          <h3 class="text-xl font-heading font-bold text-white mb-6">
            Información de Contacto
          </h3>

          <div class="space-y-6">
            <!-- Phone -->
            <a href={`tel:${phone}`} class="flex items-start gap-4 group">
              <div class="flex-shrink-0 w-11 h-11 rounded-lg flex items-center justify-center" style="background: var(--color-primary-800);">
                <svg class="w-5 h-5 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <div class="text-xs text-surface-400 mb-0.5">Teléfono</div>
                <div class="text-white font-semibold group-hover:text-accent-400 transition-colors">{phoneDisplay}</div>
              </div>
            </a>

            <!-- WhatsApp -->
            <a href={`https://wa.me/${whatsapp}?text=${encodeURIComponent(whatsappMessage)}`} target="_blank" rel="noopener" class="flex items-start gap-4 group">
              <div class="flex-shrink-0 w-11 h-11 rounded-lg flex items-center justify-center bg-green-900/50">
                <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                </svg>
              </div>
              <div>
                <div class="text-xs text-surface-400 mb-0.5">WhatsApp</div>
                <div class="text-white font-semibold group-hover:text-green-400 transition-colors">{phoneDisplay}</div>
              </div>
            </a>

            <!-- Email -->
            <a href={`mailto:${email}`} class="flex items-start gap-4 group">
              <div class="flex-shrink-0 w-11 h-11 rounded-lg flex items-center justify-center" style="background: var(--color-primary-800);">
                <svg class="w-5 h-5 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <div class="text-xs text-surface-400 mb-0.5">Email</div>
                <div class="text-white font-semibold group-hover:text-accent-400 transition-colors break-all">{email}</div>
              </div>
            </a>

            <!-- Horario -->
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-11 h-11 rounded-lg flex items-center justify-center" style="background: var(--color-primary-800);">
                <svg class="w-5 h-5 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <div class="text-xs text-surface-400 mb-0.5">Horario</div>
                <div class="text-white font-semibold text-sm">Lun — Vie: 08:00 — 18:00</div>
                <div class="text-surface-400 text-xs">Sáb: 09:00 — 14:00</div>
              </div>
            </div>
          </div>

          <!-- CTA WhatsApp -->
          <a
            href={`https://wa.me/${whatsapp}?text=${encodeURIComponent(whatsappMessage)}`}
            target="_blank" rel="noopener"
            class="mt-8 w-full flex items-center justify-center gap-2 py-3 px-6 rounded-lg bg-green-600 hover:bg-green-700 text-white font-semibold text-sm transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
            Escríbenos por WhatsApp
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // ============================================================
  // FORM SUBMISSION — Web3Forms API
  // ============================================================
  declare global {
    interface Window {
      dataLayer: Record<string, unknown>[];
    }
  }

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    successMsg?.classList.add('hidden');
    errorMsg?.classList.add('hidden');

    const originalText = submitBtn.innerHTML;
    submitBtn.disabled = true;
    submitBtn.innerHTML = `
      <svg class="animate-spin w-5 h-5" viewBox="0 0 24 24" fill="none">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
      Enviando...
    `;

    try {
      const formData = new FormData(form);

      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: formData,
      });

      const result = await response.json();

      if (result.success) {
        successMsg?.classList.remove('hidden');
        form.reset();

        // GTM: evento de conversión (si GTM está configurado)
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: 'form_submit',
          form_name: 'cotizacion',
          form_service: formData.get('servicio') || '',
        });
      } else {
        throw new Error('Form submission failed');
      }
    } catch (error) {
      errorMsg?.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = originalText;
    }
  });

  // GTM: tracking clicks en WhatsApp
  document.querySelectorAll('a[href*="wa.me"]').forEach((link) => {
    link.addEventListener('click', () => {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'whatsapp_click',
        link_url: link.getAttribute('href'),
      });
    });
  });

  // GTM: tracking click en CTAs
  document.querySelectorAll('a[href="#contacto"]').forEach((link) => {
    link.addEventListener('click', () => {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'cta_click',
        cta_text: link.textContent?.trim() || '',
      });
    });
  });

  // GTM: tracking llamadas telefónicas
  document.querySelectorAll('a[href^="tel:"]').forEach((link) => {
    link.addEventListener('click', () => {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'phone_click',
        phone_number: link.getAttribute('href'),
      });
    });
  });
</script>
