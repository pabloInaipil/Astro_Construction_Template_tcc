---
// src/components/About.astro
// Sección "Sobre Nosotros" — MGI Estructuras Metálicas

import { siteConfig } from '@config/site';

const { about } = siteConfig;
---

<section id="nosotros" class="py-20 lg:py-28" style="background-color: var(--bg-section-alt);">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Visual Side -->
      <div class="relative reveal">
        <div class="relative rounded-2xl overflow-hidden aspect-[4/3]"
          style="background: linear-gradient(135deg, var(--color-primary-200), var(--color-accent-200));">
          <!-- Reemplazar con foto real del equipo o taller -->
          <img
            src="/proyectos/equipo.jpg"
            alt={`Equipo ${siteConfig.name}`}
            loading="lazy"
            class="absolute inset-0 w-full h-full object-cover"
            onerror="this.style.display='none'"
          />
          <div class="placeholder-icon absolute inset-0 flex flex-col items-center justify-center gap-3 text-primary-500 opacity-40">
            <svg class="w-20 h-20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-sm font-medium">Foto del equipo</span>
          </div>
        </div>

        <!-- Floating stat card -->
        <div class="absolute -bottom-6 -right-4 sm:-right-6 p-5 rounded-xl shadow-elevated"
          style="background-color: var(--color-primary-600);"
        >
          <div class="text-3xl font-heading font-extrabold text-white">{about.yearsExperience}</div>
          <div class="text-sm text-primary-200 font-medium">Años de<br/>experiencia</div>
        </div>
      </div>

      <!-- Content Side -->
      <div class="reveal">
        <span class="inline-block mb-3 text-xs font-semibold uppercase tracking-[0.2em]" style="color: var(--color-accent-600);">
          Sobre Nosotros
        </span>
        <h2 class="section-title mb-5">
          Construimos con <br class="hidden sm:block" />
          la solidez del acero
        </h2>
        <p class="text-base leading-relaxed mb-8" style="color: var(--text-body);" set:html={about.description}>
        </p>

        <!-- Feature list -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          {about.features.map((feature) => (
            <div class="flex gap-3">
              <div class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center"
                style="background-color: var(--color-accent-100);"
              >
                <svg class="w-5 h-5" style="color: var(--color-accent-700);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={feature.icon} />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-bold mb-0.5" style="color: var(--text-heading);">
                  {feature.title}
                </h3>
                <p class="text-xs leading-relaxed" style="color: var(--text-muted);">
                  {feature.description}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>