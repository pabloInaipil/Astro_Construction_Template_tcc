---
// src/components/Services.astro
// Sección de servicios — 4 categorías principales (desde siteConfig)

import { siteConfig } from '@config/site';

const { services } = siteConfig;
---

<section id="servicios" class="py-20 lg:py-28" style="background-color: var(--bg-section-alt);">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-14 lg:mb-18 reveal">
      <span class="inline-block mb-3 text-xs font-semibold uppercase tracking-[0.2em]" style="color: var(--color-accent-600);">
        Nuestros Servicios
      </span>
      <h2 class="section-title mb-4">
        Soluciones en acero <br class="hidden sm:block" />para cada necesidad
      </h2>
      <p class="section-subtitle mx-auto">
        Diseñamos, fabricamos e instalamos estructuras metálicas con los más altos
        estándares de calidad. Cada proyecto se ejecuta con materiales certificados
        y mano de obra especializada.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      {services.map((service) => (
        <a href="#contacto" class="group service-card reveal">
          <div class="p-6 lg:p-7 rounded-2xl border transition-all duration-300 h-full
                      hover:shadow-elevated hover:-translate-y-1"
            style="background-color: var(--bg-card); border-color: var(--border-default);">

            {/* Icon */}
            <div class="w-14 h-14 rounded-xl flex items-center justify-center mb-5 transition-colors duration-300"
              style="background-color: var(--color-accent-100);">
              <svg class="w-7 h-7 transition-colors duration-300" style="color: var(--color-accent-700);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={service.icon} />
              </svg>
            </div>

            {/* Content */}
            <h3 class="text-lg font-heading font-bold mb-2 transition-colors duration-300" style="color: var(--text-heading);">
              {service.title}
            </h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-body);">
              {service.description}
            </p>

            {/* Arrow link */}
            <div class="mt-4 flex items-center gap-1 text-xs font-semibold uppercase tracking-wider opacity-0 group-hover:opacity-100 transition-opacity duration-300"
              style="color: var(--color-accent-600);">
              Cotizar
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
