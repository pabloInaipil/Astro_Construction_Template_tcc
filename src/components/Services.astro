---
// src/components/Services.astro
// Sección de servicios — 4 categorías principales

const services = [
  {
    title: 'Ampliaciones',
    description: 'Finas terminaciones para sorprender. Ampliamos tu hogar con soluciones estructurales sólidas, respetando la arquitectura existente y normativas vigentes.',
    icon: 'M3 21V10l6-5v16M9 5l6-2v18M15 3l6 2v16M9 12h6M9 16h6M3 14h6M15 14h6',
  },
  {
    title: 'Quinchos',
    description: 'Lujosos espacios para compartir en familia. Diseñamos y construimos quinchos con parrilla, mesón y terminaciones premium para tu hogar.',
    icon: 'M3 21h18M4 21V10l8-7 8 7v11M8 14h8M8 17h8M12 3v4M2 10h2M20 10h2',
  },
  {
    title: 'Terrazas',
    description: 'Disfruta del relajo y calidad de nuestros espacios. Terrazas techadas y abiertas con estructuras de primera calidad y diseño a medida.',
    icon: 'M4 21V10l8-7 8 7v11M4 10h16M8 21v-7h8v7M2 21h20M7 10v-1M12 10V6M17 10v-1',
  },
  {
    title: 'Piscinas',
    description: 'Refréscate con la garantía y calidad de siempre. Construcción de piscinas con terminaciones de alto estándar y sistemas de mantención eficientes.',
    icon: 'M2 12h2l2-2 2 2 2-2 2 2 2-2 2 2 2-2 2 2h2M4 18h16v2a1 1 0 01-1 1H5a1 1 0 01-1-1v-2zM6 18v-4a2 2 0 012-2h8a2 2 0 012 2v4',
  },
];
---

<section id="servicios" class="py-20 lg:py-28" style="background-color: var(--bg-section-alt);">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-14 lg:mb-18 reveal">
      <span class="inline-block mb-3 text-xs font-semibold uppercase tracking-[0.2em]" style="color: var(--color-accent-600);">
        Nuestros Servicios
      </span>
      <h2 class="section-title mb-4">
        Espacios que transforman <br class="hidden sm:block" />tu forma de vivir
      </h2>
      <p class="section-subtitle mx-auto">
        Diseñamos y construimos con los más altos estándares de calidad.
        Cada proyecto se ejecuta con materiales de primera y mano de obra calificada.
      </p>
    </div>

    <!-- Grid de servicios — 2x2 -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 lg:gap-8 max-w-4xl mx-auto reveal-stagger">
      {services.map((service) => (
        <div class="group relative rounded-2xl p-7 transition-all duration-300 hover:-translate-y-1"
          style={`background-color: var(--bg-card); border: 1px solid var(--border-subtle); box-shadow: var(--shadow-soft);`}
        >
          <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300"
            style="box-shadow: var(--shadow-elevated);" aria-hidden="true"></div>

          <div class="relative z-10">
            <div class="w-14 h-14 rounded-xl flex items-center justify-center mb-5 transition-colors duration-300"
              style="background-color: var(--color-primary-100);"
            >
              <svg class="w-7 h-7 transition-colors duration-300" style="color: var(--color-primary-600);"
                fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
              >
                <path d={service.icon} />
              </svg>
            </div>

            <h3 class="text-lg font-heading font-bold mb-2" style="color: var(--text-heading);">
              {service.title}
            </h3>

            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">
              {service.description}
            </p>

            <div class="mt-5 flex items-center gap-1 text-sm font-semibold transition-colors duration-200"
              style="color: var(--color-primary-600);"
            >
              <a href="#contacto" class="group-hover:underline">Cotizar</a>
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
