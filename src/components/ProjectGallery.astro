      },
    ],
  },
  // ── REJAS Y CIERRES ──────────────────────────────────────
  {
    category: 'rejas',
    images: [
      {
        src: '/proyectos/rejas/rejas1.jpeg',
        alt: 'Reja de seguridad residencial',
        title: 'Reja de Seguridad Residencial',
