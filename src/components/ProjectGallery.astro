      },
      {
        src: '/proyectos/rejas/rejas3.jpeg',
        alt: 'Reja protección ventanas',
        title: 'Protección de Ventanas',
        description: 'Rejas de seguridad para ventanas con diseño integrado a la fachada.',
        location: 'Santiago',
      },
      {
        src: '/proyectos/rejas/rejas4.jpeg',
        alt: 'Reja decorativa',
        title: 'Reja con Diseño',
        description: 'Reja combinando seguridad y estética con acabado pintado al horno.',
        location: 'Santiago',
      },
      {
        src: '/proyectos/rejas/rejas5.jpeg',
        alt: 'Reja terminada instalada',
        title: 'Reja Instalada',
        description: 'Proyecto terminado con reja perimetral y portón de acceso peatonal.',
        location: 'Santiago',
      },
    ],
  },
  // ── PORTONES ──────────────────────────────────────────────
  {
    category: 'portones',
    images: [
      {
        src: '/proyectos/portones/portones1.jpeg',
        alt: 'Portón corredero metálico',
        title: 'Portón Corredero',
        description: 'Portón corredero de acero con sistema de rieles y acabado en madera.',
        location: 'Santiago',
      },
      {
        src: '/proyectos/portones/portones2.jpeg',
        alt: 'Portón batiente',
        title: 'Portón Batiente',
        description: 'Portón de acceso vehicular con estructura reforzada y bisagras industriales.',
        location: 'Santiago',
      },
      {
        src: '/proyectos/portones/portones3.jpeg',
        alt: 'Portón con revestimiento',
        title: 'Portón con Revestimiento',
        description: 'Portón metálico con revestimiento decorativo y acabado premium.',
        location: 'Santiago',
      },
      {
        src: '/proyectos/portones/portones4.jpeg',
        alt: 'Portón terminado instalado',
        title: 'Portón Terminado',
        description: 'Portón instalado con acabado final, pintura y herrajes completos.',
        location: 'Santiago',
      },
    ],
  },
];

// Mapa para el lightbox — incluye metadata por imagen
const projectImagesMap = projects.map((p) =>
  p.images.map((img) => ({
    src: img.src,
    title: img.title,
    description: img.description,
    location: img.location || '',
  }))
);
---

<section id="proyectos" class="py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-10 reveal">
      <span class="inline-block mb-3 text-xs font-semibold uppercase tracking-[0.2em]" style="color: var(--color-accent-600);">
        Portafolio
      </span>
      <h2 class="section-title mb-4">
        Nuestros Proyectos
      </h2>
      <p class="section-subtitle mx-auto">
        Cada proyecto refleja nuestro compromiso con la calidad y la solidez del acero.
      </p>
    </div>

    <!-- Category Filter Tabs -->
    <div class="flex justify-center mb-12 reveal">
      <div class="inline-flex flex-wrap justify-center gap-2 p-1.5 rounded-xl" style="background-color: var(--bg-section-alt);">
        {categories.map((cat) => (
          <button
            type="button"
            class="filter-btn px-4 py-2 text-sm font-medium rounded-lg transition-all duration-200 whitespace-nowrap"
            data-category={cat.id}
            aria-pressed={cat.id === 'todos' ? 'true' : 'false'}
          >
            {cat.label}
          </button>
        ))}
      </div>
    </div>

    <!-- Projects Grid -->
    <div id="projects-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {projects.map((project, projectIndex) => (
        <article
          class="project-card group rounded-2xl overflow-hidden transition-all duration-500"
          data-category={project.category}
          style={`background-color: var(--bg-card); border: 1px solid var(--border-subtle); box-shadow: var(--shadow-soft);`}
        >
          {/* Carousel Container */}
          <div class="carousel relative aspect-[4/3] overflow-hidden">
            <div
              class="carousel-track flex w-full h-full"
              style="scroll-snap-type: x mandatory; overflow-x: auto; scrollbar-width: none; -ms-overflow-style: none;"
            >
              {project.images.map((img, imgIndex) => (
                <div
                  class="carousel-slide flex-shrink-0 w-full h-full"
                  style="scroll-snap-align: start;"
                  data-title={img.title}
                  data-description={img.description}
                  data-location={img.location || ''}
                >
                  <div class="w-full h-full relative overflow-hidden bg-neutral-200 dark:bg-neutral-800">
                    <img
                      src={img.src}
                      alt={img.alt}
                      loading="lazy"
                      decoding="async"
                      class="absolute inset-0 w-full h-full object-cover cursor-pointer lightbox-trigger"
                      data-project={projectIndex}
                      data-image={imgIndex}
                    />
                  </div>
                </div>
              ))}
            </div>

            {project.images.length > 1 && (
              <>
                <button type="button" class="carousel-prev absolute left-2 top-1/2 -translate-y-1/2 w-9 h-9 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-200 z-10 backdrop-blur-sm" style="background: rgba(0,0,0,0.5); color: white;" aria-label="Imagen anterior">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
                </button>
                <button type="button" class="carousel-next absolute right-2 top-1/2 -translate-y-1/2 w-9 h-9 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-200 z-10 backdrop-blur-sm" style="background: rgba(0,0,0,0.5); color: white;" aria-label="Imagen siguiente">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
                </button>
              </>
            )}

            {project.images.length > 1 && (
              <div class="carousel-dots absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-1.5 z-10">
                {project.images.map((_, dotIndex) => (
                  <button type="button" class={`w-2 h-2 rounded-full transition-all duration-200 ${dotIndex === 0 ? 'bg-white w-5' : 'bg-white/50'}`} aria-label={`Ir a imagen ${dotIndex + 1}`} data-dot={dotIndex} />
                ))}
              </div>
            )}

            <div class="absolute top-3 right-3 px-2.5 py-1 rounded-full text-xs font-medium z-10 backdrop-blur-sm" style="background: rgba(0,0,0,0.5); color: white;">
              <span class="carousel-current">1</span>/{project.images.length}
            </div>

            <div class="absolute top-3 left-3 px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider z-10 backdrop-blur-sm" style="background: var(--color-accent-500); color: white;">
              {project.category}
            </div>
          </div>

          {/* Info — se actualiza dinámicamente con el carrusel */}
          <div class="p-5">
            <h3 class="card-title text-base font-heading font-bold mb-1.5" style="color: var(--text-heading);">
              {project.images[0].title}
            </h3>
            <p class="card-description text-sm leading-relaxed mb-3" style="color: var(--text-muted);">
              {project.images[0].description}
            </p>
            {project.images[0].location && (
              <div class="card-location flex items-center gap-1.5 text-xs" style="color: var(--text-muted);">
                <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span class="card-location-text">{project.images[0].location}</span>
              </div>
            )}
          </div>
        </article>
      ))}
    </div>

    <div class="text-center mt-12 reveal">
      <a href="#contacto" class="btn-primary px-8 py-3">¿Tienes un proyecto? Conversemos</a>
    </div>
  </div>
</section>

<!-- ===== LIGHTBOX MODAL ===== -->
<div id="lightbox" class="lightbox" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Visor de imágenes">
  <div class="lightbox-backdrop" id="lightbox-backdrop"></div>

  <button type="button" id="lightbox-close" class="lightbox-close" aria-label="Cerrar visor">
    <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <div class="lightbox-counter" id="lightbox-counter"></div>

  <button type="button" id="lightbox-prev" class="lightbox-nav lightbox-nav-prev" aria-label="Imagen anterior">
    <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
    </svg>
  </button>
  <button type="button" id="lightbox-next" class="lightbox-nav lightbox-nav-next" aria-label="Imagen siguiente">
    <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </button>

  <!-- Image + Caption container -->
  <div class="lightbox-content" id="lightbox-content">
    <div class="lightbox-image-wrapper" id="lightbox-image-wrapper">
      <img id="lightbox-img" class="lightbox-img" src="" alt="" />
    </div>
    <!-- Caption con título, descripción y ubicación -->
    <div class="lightbox-caption" id="lightbox-caption">
      <h4 class="lightbox-caption-title" id="lightbox-caption-title"></h4>
      <p class="lightbox-caption-desc" id="lightbox-caption-desc"></p>
      <span class="lightbox-caption-location" id="lightbox-caption-location"></span>
    </div>
  </div>
</div>

<style>
  /* ===== Gallery styles ===== */
  .carousel-track::-webkit-scrollbar { display: none; }
  .filter-btn { color: var(--text-muted); }
  .filter-btn:hover { color: var(--text-heading); background-color: var(--bg-card); }
  .filter-btn[aria-pressed='true'] { background-color: var(--color-primary-600); color: white; box-shadow: 0 2px 8px rgba(30, 45, 77, 0.25); }
  .project-card.is-hidden { opacity: 0; transform: scale(0.95); position: absolute; pointer-events: none; height: 0; overflow: hidden; margin: 0; padding: 0; border: none; }
  @media (hover: none) { .carousel-prev, .carousel-next { opacity: 0.8 !important; } }

  /* ===== Lightbox ===== */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .lightbox.is-open {
    opacity: 1;
    visibility: visible;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
  }

  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 10;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 50%;
    color: white;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.25);
    transform: scale(1.1);
  }

  .lightbox-counter {
    position: absolute;
    top: 1.1rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.05em;
  }

  .lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 50%;
    color: white;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .lightbox-nav:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .lightbox-nav:active {
    transform: translateY(-50%) scale(0.92);
  }

  .lightbox-nav-prev { left: 0.75rem; }
  .lightbox-nav-next { right: 0.75rem; }

  /* Content wrapper — imagen + caption */
  .lightbox-content {
    position: relative;
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 1200px;
    width: 90vw;
    max-height: 90vh;
  }

  .lightbox-image-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 70vh;
  }

  .lightbox-img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    border-radius: 0.5rem 0.5rem 0 0;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    user-select: none;
    -webkit-user-drag: none;
    opacity: 0;
    transform: scale(0.95);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .lightbox-img.is-loaded {
    opacity: 1;
    transform: scale(1);
  }

  /* Caption */
  .lightbox-caption {
    width: 100%;
    max-width: 800px;
    padding: 1rem 1.25rem;
    text-align: center;
    opacity: 0;
    transition: opacity 0.3s ease 0.15s;
  }

  .lightbox.is-open .lightbox-caption {
    opacity: 1;
  }

  .lightbox-caption-title {
    color: white;
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 0.3rem 0;
    line-height: 1.3;
  }

  .lightbox-caption-desc {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.875rem;
    margin: 0 0 0.3rem 0;
    line-height: 1.5;
  }

  .lightbox-caption-location {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.75rem;
    letter-spacing: 0.03em;
  }

  /* ===== Responsive ===== */
  @media (max-width: 639px) {
    .lightbox-close {
      top: 0.75rem;
      right: 0.75rem;
      width: 40px;
      height: 40px;
    }

    .lightbox-nav {
      width: 40px;
      height: 40px;
    }

    .lightbox-nav-prev { left: 0.4rem; }
    .lightbox-nav-next { right: 0.4rem; }

    .lightbox-content {
      width: 96vw;
    }

    .lightbox-image-wrapper {
      height: 55vh;
    }

    .lightbox-counter {
      top: 0.85rem;
      font-size: 0.8rem;
    }

    .lightbox-caption {
      padding: 0.75rem 1rem;
    }

    .lightbox-caption-title {
      font-size: 0.95rem;
    }

    .lightbox-caption-desc {
      font-size: 0.8rem;
    }
  }

  @media (min-width: 640px) and (max-width: 1023px) {
    .lightbox-image-wrapper {
      height: 65vh;
    }
  }

  @media (min-width: 1024px) {
    .lightbox-content {
      width: 80vw;
    }

    .lightbox-image-wrapper {
      height: 72vh;
    }

    .lightbox-nav {
      width: 52px;
      height: 52px;
    }

    .lightbox-nav-prev { left: 1.5rem; }
    .lightbox-nav-next { right: 1.5rem; }
  }
</style>

<script>
  // ============================================================
  // FILTRO DE CATEGORÍAS
  // ============================================================
  const filterButtons = document.querySelectorAll('.filter-btn');
  const projectCards = document.querySelectorAll<HTMLElement>('.project-card');
  filterButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const category = (btn as HTMLElement).dataset.category;
      filterButtons.forEach((b) => b.setAttribute('aria-pressed', 'false'));
      btn.setAttribute('aria-pressed', 'true');
      projectCards.forEach((card) => {
        const shouldShow = category === 'todos' || card.dataset.category === category;
        card.classList.toggle('is-hidden', !shouldShow);
      });
    });
  });

  // ============================================================
  // CARRUSELES — con actualización de metadata en tarjeta
  // ============================================================
  document.querySelectorAll('.carousel').forEach((carousel) => {
    const card = carousel.closest('.project-card') as HTMLElement;
    const track = carousel.querySelector<HTMLElement>('.carousel-track');
    const dots = carousel.querySelectorAll<HTMLButtonElement>('.carousel-dots button');
    const counter = carousel.querySelector<HTMLElement>('.carousel-current');
    const slides = carousel.querySelectorAll<HTMLElement>('.carousel-slide');
    if (!track || slides.length <= 1) return;

    const cardTitle = card?.querySelector<HTMLElement>('.card-title');
    const cardDesc = card?.querySelector<HTMLElement>('.card-description');
    const cardLocation = card?.querySelector<HTMLElement>('.card-location');
    const cardLocationText = card?.querySelector<HTMLElement>('.card-location-text');

    let currentIndex = 0;
    const total = slides.length;

    function updateCardInfo(index: number) {
      const slide = slides[index];
      if (!slide) return;

      if (cardTitle) cardTitle.textContent = slide.dataset.title || '';
      if (cardDesc) cardDesc.textContent = slide.dataset.description || '';

      if (cardLocation && cardLocationText) {
        const loc = slide.dataset.location || '';
        if (loc) {
          cardLocationText.textContent = loc;
          cardLocation.style.display = '';
        } else {
          cardLocation.style.display = 'none';
        }
      }
    }

    function goToSlide(index: number) {
      if (index < 0) index = total - 1;
      if (index >= total) index = 0;
      currentIndex = index;
      track!.scrollTo({ left: track!.clientWidth * index, behavior: 'smooth' });
      dots.forEach((dot, i) => {
        dot.classList.toggle('bg-white', i === index);
        dot.classList.toggle('w-5', i === index);
        dot.classList.toggle('bg-white/50', i !== index);
      });
      if (counter) counter.textContent = String(index + 1);
      updateCardInfo(index);
    }

    carousel.querySelector('.carousel-prev')?.addEventListener('click', (e) => {
      e.stopPropagation();
      goToSlide(currentIndex - 1);
    });
    carousel.querySelector('.carousel-next')?.addEventListener('click', (e) => {
      e.stopPropagation();
      goToSlide(currentIndex + 1);
    });
    dots.forEach((dot) => dot.addEventListener('click', (e) => {
      e.stopPropagation();
      goToSlide(Number(dot.dataset.dot));
    }));

    let scrollTimeout: ReturnType<typeof setTimeout>;
    track.addEventListener('scroll', () => {
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(() => {
        const newIndex = Math.round(track.scrollLeft / track.clientWidth);
        if (newIndex !== currentIndex) goToSlide(newIndex);
      }, 50);
    }, { passive: true });

    carousel.addEventListener('keydown', (e: Event) => {
      const ke = e as KeyboardEvent;
      if (ke.key === 'ArrowLeft') goToSlide(currentIndex - 1);
      if (ke.key === 'ArrowRight') goToSlide(currentIndex + 1);
    });
  });
</script>

<script define:vars={{ projectImagesMap }}>
  // ============================================================
  // LIGHTBOX — con caption dinámico (título, descripción, ubicación)
  // ============================================================
  var lightbox = document.getElementById('lightbox');
  var lightboxImg = document.getElementById('lightbox-img');
  var lightboxClose = document.getElementById('lightbox-close');
  var lightboxPrev = document.getElementById('lightbox-prev');
  var lightboxNext = document.getElementById('lightbox-next');
  var lightboxBackdrop = document.getElementById('lightbox-backdrop');
  var lightboxCounter = document.getElementById('lightbox-counter');
  var lightboxCaptionTitle = document.getElementById('lightbox-caption-title');
  var lightboxCaptionDesc = document.getElementById('lightbox-caption-desc');
  var lightboxCaptionLocation = document.getElementById('lightbox-caption-location');

  var currentProjectImages = [];
  var currentLightboxIndex = 0;

  function openLightbox(projectIdx, imageIdx) {
    currentProjectImages = projectImagesMap[projectIdx] || [];
    currentLightboxIndex = imageIdx;
    if (currentProjectImages.length === 0) return;

    showLightboxImage();
    lightbox.classList.add('is-open');
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';

    var hasMultiple = currentProjectImages.length > 1;
    lightboxPrev.style.display = hasMultiple ? 'flex' : 'none';
    lightboxNext.style.display = hasMultiple ? 'flex' : 'none';
    lightboxCounter.style.display = hasMultiple ? 'block' : 'none';
  }

  function closeLightbox() {
    lightbox.classList.remove('is-open');
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    setTimeout(function() {
      lightboxImg.src = '';
      lightboxImg.alt = '';
      lightboxImg.classList.remove('is-loaded');
      lightboxCaptionTitle.textContent = '';
      lightboxCaptionDesc.textContent = '';
      lightboxCaptionLocation.textContent = '';
    }, 300);
  }

  function showLightboxImage() {
    var imgData = currentProjectImages[currentLightboxIndex];
    if (!imgData) return;

    lightboxImg.classList.remove('is-loaded');
    lightboxImg.src = imgData.src;
    lightboxImg.alt = imgData.title;
    lightboxCounter.textContent = (currentLightboxIndex + 1) + ' / ' + currentProjectImages.length;

    if (lightboxImg.complete && lightboxImg.naturalWidth > 0) {
      lightboxImg.classList.add('is-loaded');
    } else {
      lightboxImg.onload = function() { lightboxImg.classList.add('is-loaded'); };
    }

    lightboxCaptionTitle.textContent = imgData.title;
    lightboxCaptionDesc.textContent = imgData.description;
    lightboxCaptionLocation.textContent = imgData.location || '';
  }

  function lightboxGo(direction) {
    currentLightboxIndex += direction;
    if (currentLightboxIndex < 0) currentLightboxIndex = currentProjectImages.length - 1;
    if (currentLightboxIndex >= currentProjectImages.length) currentLightboxIndex = 0;
    showLightboxImage();
  }

  // --- Event listeners ---
  document.querySelectorAll('.lightbox-trigger').forEach(function(img) {
    img.addEventListener('click', function(e) {
      e.stopPropagation();
      var projectIdx = parseInt(img.dataset.project, 10);
      var imageIdx = parseInt(img.dataset.image, 10);
      openLightbox(projectIdx, imageIdx);
    });
  });

  lightboxClose.addEventListener('click', closeLightbox);
  lightboxBackdrop.addEventListener('click', closeLightbox);

  lightboxPrev.addEventListener('click', function() { lightboxGo(-1); });
  lightboxNext.addEventListener('click', function() { lightboxGo(1); });

  document.addEventListener('keydown', function(e) {
    if (!lightbox.classList.contains('is-open')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') lightboxGo(-1);
    if (e.key === 'ArrowRight') lightboxGo(1);
  });

  // Touch swipe
  var lbTouchStartX = 0;
  var lbTouchStartY = 0;

  lightbox.addEventListener('touchstart', function(e) {
    lbTouchStartX = e.changedTouches[0].screenX;
    lbTouchStartY = e.changedTouches[0].screenY;
  }, { passive: true });

  lightbox.addEventListener('touchend', function(e) {
    var diffX = lbTouchStartX - e.changedTouches[0].screenX;
    var diffY = lbTouchStartY - e.changedTouches[0].screenY;
    if (Math.abs(diffX) > 50 && Math.abs(diffX) > Math.abs(diffY)) {
      if (diffX > 0) lightboxGo(1);
      else lightboxGo(-1);
    }
  }, { passive: true });
</script>