        location: 'Santiago',
      },
    ],
  },
  // ── GALPONES — Proyecto 2 ─────────────────────────────────
  {
    category: 'galpones',
    images: [
      {
        src: '/proyectos/galpones/galpones6.jpeg',
        alt: 'Galpón terminado exterior',
        title: 'Galpón Nave Industrial',
        description: 'Nave industrial terminada con revestimiento metálico y portón de acceso vehicular.',
        location: 'Santiago',
      },
      {
        src: '/proyectos/galpones/galpones7.jpeg',
        alt: 'Galpón interior terminado',
        title: 'Interior Terminado',
        description: 'Vista interior con iluminación natural, piso industrial y altura libre óptima.',
        location: 'Santiago',
      },
      {
        src: '/proyectos/galpones/galpones8.jpeg',
        alt: 'Galpón detalle estructura',
        title: 'Detalle Estructural',
        description: 'Uniones soldadas y empernadas con acabado anticorrosivo.',
        location: 'Santiago',
      },
      {
        src: '/proyectos/galpones/galpones9.jpeg',
        alt: 'Galpón vista lateral',
        title: 'Vista Lateral',
        description: 'Perfil lateral del galpón con ventilación natural integrada.',
        location: 'Santiago',
      },
      {
        src: '/proyectos/galpones/galpones10.jpeg',
        alt: 'Galpón terminado vista general',
        title: 'Galpón Terminado',
        description: 'Vista general del proyecto finalizado con accesos y terminaciones completas.',
        location: 'Santiago',
      },
    ],
  },
  // ── CASAS METÁLICAS ───────────────────────────────────────
  {
    category: 'casasmetal',
    images: [
      {
        src: '/proyectos/casasmetal/casasmetal1.jpeg',
        alt: 'Casa metálica estructura inicial',
        title: 'Casa Metálica — Estructura',
        description: 'Montaje de estructura de acero liviano para vivienda con diseño moderno.',
        location: 'Santiago',
      },
      {
        src: '/proyectos/casasmetal/casasmetal2.jpeg',
        alt: 'Casa metálica avance de obra',
        title: 'Avance de Obra',
        description: 'Instalación de perfilería metálica y preparación para revestimientos.',
        location: 'Santiago',
      },
      {
        src: '/proyectos/casasmetal/casasmetal3.jpeg',
        alt: 'Casa metálica cerramientos',
        title: 'Cerramientos y Revestimiento',
        description: 'Colocación de revestimientos exteriores sobre estructura metálica.',
        location: 'Santiago',
      },
      {
        src: '/proyectos/casasmetal/casasmetal4.jpeg',
        alt: 'Casa metálica avance exterior',
