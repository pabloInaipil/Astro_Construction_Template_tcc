        description: 'Espacio interior del galpón con estructura completa lista para cubierta.',
        location: 'Santiago',
      },
      {
        src: '/proyectos/galpones/galpones5.jpeg',
        alt: 'Galpón cubierta instalada',
        title: 'Instalación de Cubierta',
