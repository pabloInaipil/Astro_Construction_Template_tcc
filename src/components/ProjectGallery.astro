---
// src/components/ProjectGallery.astro
// Galería de proyectos — Filtro por categoría + carrusel por proyecto.
// Cada imagen tiene su propio título, descripción y ubicación.
// Al navegar el carrusel, la info de la tarjeta y del lightbox se actualiza.

interface ProjectImage {
  src: string;
  alt: string;
  title: string;
  description: string;
  location?: string;
}

interface Project {
  category: string;
  images: ProjectImage[];
}

const categories = [
  { id: 'todos', label: 'Todos' },
  { id: 'ampliaciones', label: 'Ampliaciones' },
  { id: 'quinchos', label: 'Quinchos' },
  { id: 'terrazas', label: 'Terrazas' },
  { id: 'piscinas', label: 'Piscinas' },
];

// ============================================================
// CATÁLOGO DE PROYECTOS
// Para agregar un proyecto nuevo, copia un bloque { category, images }
// y edita los campos. Cada imagen lleva su propio título/descripción.
// ============================================================
const projects: Project[] = [
  {
    category: 'ampliaciones',
