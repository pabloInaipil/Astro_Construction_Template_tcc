---
// src/components/ProjectGallery.astro
// Galería de proyectos — Filtro por categoría + carrusel por proyecto.
// Cada imagen tiene su propio título, descripción y ubicación.
// Al navegar el carrusel, la info de la tarjeta y del lightbox se actualiza.

import { siteConfig } from '@config/site';

interface ProjectImage {
  src: string;
  alt: string;
  title: string;
  description: string;
  location?: string;
}

interface Project {
  category: string;
  images: ProjectImage[];
}

const { categories } = siteConfig;

// ============================================================
// CATÁLOGO DE PROYECTOS — MGI Estructuras Metálicas
// Para agregar un proyecto nuevo, copia un bloque { category, images }
// y edita los campos. Cada imagen lleva su propio título/descripción.
// ============================================================
const projects: Project[] = [
  // ── GALPONES — Proyecto 1 ─────────────────────────────────
  {
    category: 'galpones',
    images: [
      {
        src: '/proyectos/galpones/galpones1.jpeg',
        alt: 'Galpón estructura metálica en construcción',
        title: 'Galpón Industrial — Estructura',
        description: 'Montaje de estructura de acero para galpón industrial con cerchas metálicas de alta resistencia.',
        location: 'Santiago',
      },
      {
        src: '/proyectos/galpones/galpones2.jpeg',
        alt: 'Galpón avance de obra',
        title: 'Avance de Obra — Columnas',
        description: 'Instalación de columnas y vigas principales con soldaduras certificadas.',
        location: 'Santiago',
      },
      {
        src: '/proyectos/galpones/galpones3.jpeg',
        alt: 'Galpón estructura de cerchas',
        title: 'Cerchas Metálicas',
