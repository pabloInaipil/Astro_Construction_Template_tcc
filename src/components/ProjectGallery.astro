  .lightbox.is-open .lightbox-caption {
    opacity: 1;
  }

  .lightbox-caption-title {
    color: white;
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 0.3rem 0;
