<script>
  // ============================================================
  // FILTRO DE CATEGORÍAS
  // ============================================================
  const filterButtons = document.querySelectorAll('.filter-btn');
  const projectCards = document.querySelectorAll<HTMLElement>('.project-card');
  filterButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const category = (btn as HTMLElement).dataset.category;
      filterButtons.forEach((b) => b.setAttribute('aria-pressed', 'false'));
      btn.setAttribute('aria-pressed', 'true');
      projectCards.forEach((card) => {
        const shouldShow = category === 'todos' || card.dataset.category === category;
        card.classList.toggle('is-hidden', !shouldShow);
      });
    });
  });

  // ============================================================
  // CARRUSELES — con actualización de metadata en tarjeta
  // ============================================================
  document.querySelectorAll('.carousel').forEach((carousel) => {
    const card = carousel.closest('.project-card') as HTMLElement;
    const track = carousel.querySelector<HTMLElement>('.carousel-track');
    const dots = carousel.querySelectorAll<HTMLButtonElement>('.carousel-dots button');
    const counter = carousel.querySelector<HTMLElement>('.carousel-current');
    const slides = carousel.querySelectorAll<HTMLElement>('.carousel-slide');
    if (!track || slides.length <= 1) return;

    const cardTitle = card?.querySelector<HTMLElement>('.card-title');
    const cardDesc = card?.querySelector<HTMLElement>('.card-description');
    const cardLocation = card?.querySelector<HTMLElement>('.card-location');
    const cardLocationText = card?.querySelector<HTMLElement>('.card-location-text');

    let currentIndex = 0;
    const total = slides.length;

    function updateCardInfo(index: number) {
      const slide = slides[index];
      if (!slide) return;

      if (cardTitle) cardTitle.textContent = slide.dataset.title || '';
      if (cardDesc) cardDesc.textContent = slide.dataset.description || '';

      if (cardLocation && cardLocationText) {
        const loc = slide.dataset.location || '';
        if (loc) {
          cardLocationText.textContent = loc;
          cardLocation.style.display = '';
        } else {
          cardLocation.style.display = 'none';
        }
      }
    }

    function goToSlide(index: number) {
      if (index < 0) index = total - 1;
      if (index >= total) index = 0;
      currentIndex = index;
      track!.scrollTo({ left: track!.clientWidth * index, behavior: 'smooth' });
      dots.forEach((dot, i) => {
        dot.classList.toggle('bg-white', i === index);
        dot.classList.toggle('w-5', i === index);
        dot.classList.toggle('bg-white/50', i !== index);
      });
      if (counter) counter.textContent = String(index + 1);
      updateCardInfo(index);
    }

    carousel.querySelector('.carousel-prev')?.addEventListener('click', (e) => {
      e.stopPropagation();
      goToSlide(currentIndex - 1);
    });
    carousel.querySelector('.carousel-next')?.addEventListener('click', (e) => {
      e.stopPropagation();
      goToSlide(currentIndex + 1);
    });
    dots.forEach((dot) => dot.addEventListener('click', (e) => {
      e.stopPropagation();
      goToSlide(Number(dot.dataset.dot));
    }));

    let scrollTimeout: ReturnType<typeof setTimeout>;
    track.addEventListener('scroll', () => {
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(() => {
        const newIndex = Math.round(track.scrollLeft / track.clientWidth);
        if (newIndex !== currentIndex) goToSlide(newIndex);
      }, 50);
    }, { passive: true });

    carousel.addEventListener('keydown', (e: Event) => {
      const ke = e as KeyboardEvent;
      if (ke.key === 'ArrowLeft') goToSlide(currentIndex - 1);
      if (ke.key === 'ArrowRight') goToSlide(currentIndex + 1);
    });
  });
</script>

<script define:vars={{ projectImagesMap }}>
  // ============================================================
  // LIGHTBOX — con caption dinámico (título, descripción, ubicación)
  // ============================================================
  var lightbox = document.getElementById('lightbox');
  var lightboxImg = document.getElementById('lightbox-img');
  var lightboxClose = document.getElementById('lightbox-close');
  var lightboxPrev = document.getElementById('lightbox-prev');
  var lightboxNext = document.getElementById('lightbox-next');
  var lightboxBackdrop = document.getElementById('lightbox-backdrop');
  var lightboxCounter = document.getElementById('lightbox-counter');
  var lightboxCaptionTitle = document.getElementById('lightbox-caption-title');
  var lightboxCaptionDesc = document.getElementById('lightbox-caption-desc');
  var lightboxCaptionLocation = document.getElementById('lightbox-caption-location');

  var currentProjectImages = [];
  var currentLightboxIndex = 0;

  function openLightbox(projectIdx, imageIdx) {
    currentProjectImages = projectImagesMap[projectIdx] || [];
    currentLightboxIndex = imageIdx;
    if (currentProjectImages.length === 0) return;

    showLightboxImage();
    lightbox.classList.add('is-open');
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';

    var hasMultiple = currentProjectImages.length > 1;
    lightboxPrev.style.display = hasMultiple ? 'flex' : 'none';
    lightboxNext.style.display = hasMultiple ? 'flex' : 'none';
    lightboxCounter.style.display = hasMultiple ? 'block' : 'none';
  }

  function closeLightbox() {
    lightbox.classList.remove('is-open');
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    setTimeout(function() {
      lightboxImg.src = '';
      lightboxImg.alt = '';
      lightboxImg.classList.remove('is-loaded');
      lightboxCaptionTitle.textContent = '';
      lightboxCaptionDesc.textContent = '';
      lightboxCaptionLocation.textContent = '';
    }, 300);
  }

  function showLightboxImage() {
    var imgData = currentProjectImages[currentLightboxIndex];
    if (!imgData) return;

    // Imagen
    lightboxImg.classList.remove('is-loaded');
    lightboxImg.src = imgData.src;
    lightboxImg.alt = imgData.title;
    lightboxCounter.textContent = (currentLightboxIndex + 1) + ' / ' + currentProjectImages.length;

    if (lightboxImg.complete && lightboxImg.naturalWidth > 0) {
      lightboxImg.classList.add('is-loaded');
    } else {
      lightboxImg.onload = function() { lightboxImg.classList.add('is-loaded'); };
    }

    // Caption
    lightboxCaptionTitle.textContent = imgData.title;
    lightboxCaptionDesc.textContent = imgData.description;
    lightboxCaptionLocation.textContent = imgData.location || '';
  }

  function lightboxGo(direction) {
    currentLightboxIndex += direction;
    if (currentLightboxIndex < 0) currentLightboxIndex = currentProjectImages.length - 1;
    if (currentLightboxIndex >= currentProjectImages.length) currentLightboxIndex = 0;
    showLightboxImage();
  }

  // --- Event listeners ---

  document.querySelectorAll('.lightbox-trigger').forEach(function(img) {
    img.addEventListener('click', function(e) {
      e.stopPropagation();
      var projectIdx = parseInt(img.dataset.project, 10);
      var imageIdx = parseInt(img.dataset.image, 10);
      openLightbox(projectIdx, imageIdx);
    });
  });

  lightboxClose.addEventListener('click', closeLightbox);
  lightboxBackdrop.addEventListener('click', closeLightbox);

  lightboxPrev.addEventListener('click', function() { lightboxGo(-1); });
  lightboxNext.addEventListener('click', function() { lightboxGo(1); });

  document.addEventListener('keydown', function(e) {
    if (!lightbox.classList.contains('is-open')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') lightboxGo(-1);
    if (e.key === 'ArrowRight') lightboxGo(1);
  });

  // Touch swipe
  var lbTouchStartX = 0;
  var lbTouchStartY = 0;

  lightbox.addEventListener('touchstart', function(e) {
    lbTouchStartX = e.changedTouches[0].screenX;
    lbTouchStartY = e.changedTouches[0].screenY;
  }, { passive: true });

  lightbox.addEventListener('touchend', function(e) {
    var diffX = lbTouchStartX - e.changedTouches[0].screenX;
    var diffY = lbTouchStartY - e.changedTouches[0].screenY;
    if (Math.abs(diffX) > 50 && Math.abs(diffX) > Math.abs(diffY)) {
      if (diffX > 0) lightboxGo(1);
      else lightboxGo(-1);
    }
  }, { passive: true });
</script>