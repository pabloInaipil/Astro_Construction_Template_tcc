---
// src/components/Stats.astro
// Barra de estadísticas con contadores animados

const stats = [
  { value: '10+', label: 'Años de Experiencia' },
  { value: '500+', label: 'Proyectos Realizados' },
  { value: '98%', label: 'Clientes Satisfechos' },
  { value: '100%', label: 'Compromiso y Garantía' },
];
---

<section class="relative py-12 lg:py-16 overflow-hidden" style="background-color: var(--color-primary-600);">
  <!-- Texture overlay -->
  <div class="absolute inset-0 opacity-10" aria-hidden="true">
    <svg width="100%" height="100%">
      <defs>
        <pattern id="stats-dots" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
          <circle cx="1" cy="1" r="1" fill="white" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#stats-dots)" />
    </svg>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12 reveal-stagger">
      {stats.map((stat) => (
        <div class="text-center">
          <div class="text-3xl sm:text-4xl lg:text-5xl font-heading font-extrabold text-white mb-1">
            {stat.value}
          </div>
          <div class="text-sm sm:text-base text-primary-200 font-medium">
            {stat.label}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
