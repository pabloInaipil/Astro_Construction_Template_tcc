---
// src/components/Stats.astro
// ============================================================
// SECCIÓN DE ESTADÍSTICAS CON ANIMACIÓN COUNTER TIPO CASINO
// 
// Funcionamiento:
// 1. Los números se muestran inicialmente en "0"
// 2. Cuando el usuario hace scroll y la sección entra en pantalla,
//    un IntersectionObserver detecta la visibilidad
// 3. Cada número se anima de 0 al valor final usando requestAnimationFrame
// 4. La animación usa easing "easeOutQuart" (arranca rápido, frena al final)
//    similar a una ruleta de casino frenando
// 5. Cada contador arranca con 150ms de delay respecto al anterior
//    para crear un efecto escalonado (cascada)
// ============================================================

// ------------------------------------------------------------
// DATOS DE LAS ESTADÍSTICAS
// Editar aquí para cambiar valores, sufijos o etiquetas.
// - value:  número final al que llega la animación
// - suffix: texto que va pegado al número (+, %, etc.)
// - label:  texto descriptivo debajo del número
// ------------------------------------------------------------
const stats = [
  { value: 10, suffix: '+', label: 'Años de Experiencia' },
  { value: 500, suffix: '+', label: 'Proyectos Realizados' },
  { value: 98, suffix: '%', label: 'Clientes Satisfechos' },
  { value: 100, suffix: '%', label: 'Compromiso y Garantía' },
];
---

<!-- 
  CONTENEDOR DE LA SECCIÓN
  - py-16 lg:py-20: padding vertical (espaciado arriba/abajo)
  - background: color primario café (--color-primary-600)
-->
<section class="py-16 lg:py-20" style="background-color: var(--color-primary-600);">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <!-- 
      GRID DE ESTADÍSTICAS
      - 2 columnas en mobile, 4 en desktop
      - id="stats-grid" → usado por el IntersectionObserver para
        detectar cuándo la sección es visible en pantalla
    -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12" id="stats-grid">

      {stats.map((stat) => (
        <div class="text-center">
          <!-- 
            NÚMERO ANIMADO
            - .stat-counter → clase que el JS usa para encontrar los elementos
            - data-target:  valor numérico final (ej: 500)
            - data-suffix:  sufijo a mostrar (ej: "+")
            - Contenido inicial: "0+" o "0%" (se reemplaza por la animación)
            - Tipografía: grande, bold, blanca
          -->
          <div
            class="stat-counter text-4xl sm:text-5xl lg:text-6xl font-heading font-extrabold text-white"
            data-target={stat.value}
            data-suffix={stat.suffix}
          >
            0{stat.suffix}
          </div>

          <!-- 
            ETIQUETA DESCRIPTIVA
            - Color #d4a98a (beige/salmón claro, contrasta sobre el café)
          -->
          <div class="mt-2 text-sm sm:text-base font-medium" style="color: #d4a98a;">
            {stat.label}
          </div>
        </div>
      ))}

    </div>
  </div>
</section>

<script>
  // ============================================================
  // FUNCIÓN: animateCounter
  // Anima UN solo elemento de 0 hasta su valor final.
  //
  // Parámetros:
  //   el → el elemento HTML del counter (el div con .stat-counter)
  //
  // Usa requestAnimationFrame para animación suave a 60fps.
  // ============================================================
  function animateCounter(el: HTMLElement) {

    // Leer el valor final desde el atributo data-target del HTML
    // Ejemplo: data-target="500" → target = 500
    const target = parseInt(el.dataset.target || '0');

    // Leer el sufijo desde data-suffix
    // Ejemplo: data-suffix="+" → suffix = "+"
    const suffix = el.dataset.suffix || '';

    // Duración total de la animación en milisegundos
    // 2000ms = 2 segundos para ir de 0 al valor final
    const duration = 2000;

    // Marca de tiempo del inicio de la animación
    const startTime = performance.now();

    // ----------------------------------------------------------
    // FUNCIÓN DE EASING: easeOutQuart
    // 
    // Controla la "velocidad" de la animación en cada momento.
    // - Al inicio (t ≈ 0): avanza MUY rápido (efecto casino/ruleta)
    // - Al final (t ≈ 1): desacelera y frena suavemente
    //
    // Fórmula: 1 - (1 - t)^4
    //   t = 0.0 → resultado = 0.0 (inicio)
    //   t = 0.25 → resultado = 0.68 (ya avanzó 68%!)
    //   t = 0.5  → resultado = 0.94 (casi llegó)
    //   t = 1.0  → resultado = 1.0 (fin)
    //
    // Sin easing, el número subiría a velocidad constante (aburrido).
    // Con easeOutQuart, "dispara" rápido y frena como ruleta.
    // ----------------------------------------------------------
    function easeOutQuart(t: number): number {
      return 1 - Math.pow(1 - t, 4);
    }

    // ----------------------------------------------------------
    // FUNCIÓN: update (se ejecuta en cada frame, ~60 veces/segundo)
    //
    // 1. Calcula cuánto tiempo ha pasado desde el inicio
    // 2. Convierte ese tiempo en un progreso de 0 a 1
    // 3. Aplica el easing para obtener el progreso "suavizado"
    // 4. Calcula el número actual (progreso × valor final)
    // 5. Actualiza el texto del elemento
    // 6. Si no terminó, pide otro frame
    // ----------------------------------------------------------
    function update(currentTime: number) {

      // Tiempo transcurrido desde que empezó la animación
      const elapsed = currentTime - startTime;

      // Progreso lineal: 0 (inicio) a 1 (fin), sin pasarse de 1
      const progress = Math.min(elapsed / duration, 1);

      // Progreso con easing aplicado (rápido→lento)
      const easedProgress = easeOutQuart(progress);

      // Valor numérico actual: porcentaje del target
      // Ejemplo con target=500, easedProgress=0.68 → 340
      const currentValue = Math.round(easedProgress * target);

      // Actualizar el texto visible en pantalla
      // toLocaleString('es-CL') formatea con separador de miles (ej: 1.500)
      el.textContent = currentValue.toLocaleString('es-CL') + suffix;

      // Si aún no llegamos al 100%, seguir animando
      // requestAnimationFrame llama a update() en el siguiente frame (~16ms)
      if (progress < 1) {
        requestAnimationFrame(update);
      }
    }

    // Iniciar el loop de animación
    requestAnimationFrame(update);
  }

  // ============================================================
  // INTERSECTION OBSERVER
  //
  // Detecta cuándo el grid de estadísticas entra en la pantalla.
  // Sin esto, la animación correría al cargar la página aunque
  // el usuario no haya hecho scroll — nunca la vería.
  //
  // threshold: 0.3 → se activa cuando el 30% de la sección
  //                   es visible en el viewport
  // ============================================================
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {

      // ¿La sección es visible?
      if (entry.isIntersecting) {

        // Buscar TODOS los elementos con clase .stat-counter dentro del grid
        const counters = entry.target.querySelectorAll<HTMLElement>('.stat-counter');

        // Animar cada contador con delay escalonado
        // i=0 → arranca inmediato (0ms)
        // i=1 → arranca a los 150ms
        // i=2 → arranca a los 300ms
        // i=3 → arranca a los 450ms
        // Esto crea el efecto "cascada" tipo casino
        counters.forEach((counter, i) => {
          setTimeout(() => animateCounter(counter), i * 150);
        });

        // Dejar de observar — la animación solo corre UNA vez
        // Si quisieras que se repita cada vez que aparece,
        // quita esta línea
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.3 });

  // ============================================================
  // INICIALIZACIÓN
  // Conectar el observer al grid de estadísticas.
  // A partir de aquí, el observer "vigila" si el grid es visible.
  // ============================================================
  const grid = document.getElementById('stats-grid');
  if (grid) observer.observe(grid);
</script>