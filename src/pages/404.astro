---
// src/pages/404.astro
import Layout from '@layouts/Layout.astro';
---

<Layout title="Página no encontrada — TodoCasa Construcciones" noindex={true}>
  <section class="min-h-[70vh] flex items-center justify-center px-4 pt-20">
    <div class="text-center max-w-md">
      <div class="text-8xl font-heading font-extrabold mb-4" style="color: var(--color-primary-300);">
        404
      </div>
      <h1 class="text-2xl font-heading font-bold mb-3" style="color: var(--text-heading);">
        Página no encontrada
      </h1>
      <p class="text-base mb-8" style="color: var(--text-muted);">
        La página que buscas no existe o fue movida.
        Te invitamos a volver al inicio.
      </p>
      <a href="/" class="btn-primary px-8 py-3">
        Volver al Inicio
      </a>
    </div>
  </section>
</Layout>
